{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene-validation-report-v1.schema.json",
  "title": "SceneValidationReportV1",
  "type": "object",
  "required": [
    "sceneValidationReportVersion",
    "scene",
    "valid",
    "errors",
    "warnings",
    "systems"
  ],
  "properties": {
    "sceneValidationReportVersion": { "const": 1 },
    "scene": { "type": "string" },
    "valid": { "type": "boolean" },
    "errors": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "warnings": {
      "type": "array",
      "items": { "$ref": "#/$defs/issue" }
    },
    "systems": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "known"],
        "properties": {
          "name": { "type": "string" },
          "known": { "type": "boolean" },
          "delta": { "type": "integer" },
          "deterministic": { "type": "boolean" }
        },
        "additionalProperties": false
      }
    }
  },
  "$defs": {
    "issue": {
      "type": "object",
      "required": ["code", "message"],
      "properties": {
        "code": { "type": "string" },
        "message": { "type": "string" },
        "path": { "type": "string" },
        "system": { "type": "string" }
      },
      "additionalProperties": false
    }
  },
  "additionalProperties": false
}

