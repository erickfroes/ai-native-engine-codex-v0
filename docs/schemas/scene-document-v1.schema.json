{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "scene-document-v1.schema.json",
  "title": "SceneDocumentV1",
  "type": "object",
  "required": [
    "version",
    "metadata",
    "systems",
    "entities"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "metadata": {
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "author": { "type": "string" },
        "tags": {
          "type": "array",
          "items": { "type": "string" }
        }
      },
      "additionalProperties": true
    },
    "systems": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "string"
      }
    },
    "assetRefs": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "entities": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["id", "components"],
        "properties": {
          "id": { "type": "string" },
          "name": { "type": "string" },
          "prefab": { "type": "string" },
          "components": {
            "type": "array",
            "items": {
              "$ref": "../../schemas/component.schema.json"
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

