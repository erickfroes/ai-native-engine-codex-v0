{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "component-registry-v1.schema.json",
  "title": "ComponentRegistryV1",
  "type": "object",
  "required": ["componentRegistryVersion", "components"],
  "properties": {
    "componentRegistryVersion": {
      "type": "integer",
      "const": 1
    },
    "components": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["name", "version", "deterministic", "description"],
        "properties": {
          "name": { "type": "string" },
          "version": { "type": "integer", "minimum": 1 },
          "deterministic": { "type": "boolean" },
          "description": { "type": "string" }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
