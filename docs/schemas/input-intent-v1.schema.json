{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "input-intent-v1.schema.json",
  "title": "InputIntentV1",
  "type": "object",
  "required": [
    "inputIntentVersion",
    "tick",
    "entityId",
    "actions"
  ],
  "properties": {
    "inputIntentVersion": {
      "type": "integer",
      "const": 1
    },
    "tick": {
      "type": "integer",
      "minimum": 1
    },
    "entityId": {
      "type": "string"
    },
    "actions": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "type",
          "axis"
        ],
        "properties": {
          "type": {
            "enum": ["move"]
          },
          "axis": {
            "type": "object",
            "required": [
              "x",
              "y"
            ],
            "properties": {
              "x": {
                "type": "integer",
                "minimum": -1
              },
              "y": {
                "type": "integer",
                "minimum": -1
              }
            },
            "additionalProperties": false
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
