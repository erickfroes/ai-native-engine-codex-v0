{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset-manifest-v1.schema.json",
  "title": "AssetManifestV1",
  "type": "object",
  "required": [
    "assetManifestVersion",
    "assets"
  ],
  "properties": {
    "assetManifestVersion": {
      "type": "integer",
      "const": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "id",
          "type",
          "src",
          "width",
          "height"
        ],
        "properties": {
          "id": {
            "type": "string"
          },
          "type": {
            "type": "string",
            "enum": ["image"]
          },
          "src": {
            "type": "string"
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
