{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "render-snapshot-v1.schema.json",
  "title": "RenderSnapshotV1",
  "type": "object",
  "required": [
    "renderSnapshotVersion",
    "scene",
    "tick",
    "viewport",
    "drawCalls"
  ],
  "properties": {
    "renderSnapshotVersion": {
      "type": "integer",
      "const": 1
    },
    "scene": {
      "type": "string"
    },
    "tick": {
      "type": "integer",
      "minimum": 0
    },
    "viewport": {
      "type": "object",
      "required": [
        "width",
        "height"
      ],
      "properties": {
        "width": {
          "type": "integer",
          "minimum": 1
        },
        "height": {
          "type": "integer",
          "minimum": 1
        }
      },
      "additionalProperties": false
    },
    "drawCalls": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "kind",
          "id",
          "x",
          "y",
          "width",
          "height",
          "layer"
        ],
        "properties": {
          "kind": {
            "type": "string",
            "enum": ["rect"]
          },
          "id": {
            "type": "string"
          },
          "x": {
            "type": "integer"
          },
          "y": {
            "type": "integer"
          },
          "width": {
            "type": "integer",
            "minimum": 1
          },
          "height": {
            "type": "integer",
            "minimum": 1
          },
          "layer": {
            "type": "integer"
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}
