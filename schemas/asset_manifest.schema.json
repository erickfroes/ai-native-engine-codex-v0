{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "asset_manifest.schema.json",
  "title": "AssetManifest",
  "type": "object",
  "required": [
    "version",
    "assets"
  ],
  "properties": {
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "assets": {
      "type": "array",
      "items": {
        "type": "string"
      },
      "minItems": 1
    }
  },
  "additionalProperties": false
}
