{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "prefab.schema.json",
  "title": "Prefab",
  "type": "object",
  "required": [
    "id",
    "version",
    "components"
  ],
  "properties": {
    "id": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "tags": {
      "type": "array",
      "items": {
        "type": "string"
      }
    },
    "components": {
      "type": "array",
      "minItems": 1,
      "items": {
        "$ref": "component.schema.json"
      }
    }
  },
  "additionalProperties": false
}
