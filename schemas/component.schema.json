{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "component.schema.json",
  "title": "Component",
  "type": "object",
  "required": [
    "kind",
    "version",
    "replicated",
    "fields"
  ],
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "replicated": {
      "type": "boolean"
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "visual.sprite"
          }
        }
      },
      "then": {
        "properties": {
          "kind": {
            "const": "visual.sprite"
          },
          "version": {
            "const": 1
          },
          "replicated": {
            "const": false
          },
          "fields": {
            "type": "object",
            "required": [
              "assetId"
            ],
            "properties": {
              "assetId": {
                "type": "string",
                "minLength": 1
              },
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              },
              "layer": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "tile.layer"
          }
        }
      },
      "then": {
        "properties": {
          "kind": {
            "const": "tile.layer"
          },
          "version": {
            "const": 1
          },
          "replicated": {
            "const": false
          },
          "fields": {
            "type": "object",
            "required": [
              "tileWidth",
              "tileHeight",
              "columns",
              "rows",
              "tiles",
              "palette"
            ],
            "properties": {
              "tileWidth": {
                "type": "integer",
                "minimum": 1
              },
              "tileHeight": {
                "type": "integer",
                "minimum": 1
              },
              "columns": {
                "type": "integer",
                "minimum": 1
              },
              "rows": {
                "type": "integer",
                "minimum": 1
              },
              "layer": {
                "type": "integer"
              },
              "tiles": {
                "type": "array",
                "items": {
                  "type": "array",
                  "items": {
                    "oneOf": [
                      {
                        "type": "integer"
                      },
                      {
                        "type": "string",
                        "minLength": 1
                      }
                    ]
                  }
                }
              },
              "palette": {
                "type": "object",
                "minProperties": 1,
                "additionalProperties": {
                  "oneOf": [
                    {
                      "type": "object",
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "empty"
                        }
                      },
                      "additionalProperties": false
                    },
                    {
                      "type": "object",
                      "required": [
                        "kind"
                      ],
                      "properties": {
                        "kind": {
                          "const": "rect"
                        },
                        "width": {
                          "type": "integer",
                          "minimum": 1
                        },
                        "height": {
                          "type": "integer",
                          "minimum": 1
                        }
                      },
                      "additionalProperties": false
                    }
                  ]
                }
              }
            },
            "additionalProperties": false
          }
        }
      }
    },
    {
      "if": {
        "properties": {
          "kind": {
            "const": "camera.viewport"
          }
        }
      },
      "then": {
        "properties": {
          "kind": {
            "const": "camera.viewport"
          },
          "version": {
            "const": 1
          },
          "replicated": {
            "const": false
          },
          "fields": {
            "type": "object",
            "required": [
              "x",
              "y",
              "width",
              "height"
            ],
            "properties": {
              "x": {
                "type": "integer"
              },
              "y": {
                "type": "integer"
              },
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
