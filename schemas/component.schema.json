{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "component.schema.json",
  "title": "Component",
  "type": "object",
  "required": [
    "kind",
    "version",
    "replicated",
    "fields"
  ],
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "replicated": {
      "type": "boolean"
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "allOf": [
    {
      "if": {
        "properties": {
          "kind": {
            "const": "visual.sprite"
          }
        }
      },
      "then": {
        "properties": {
          "kind": {
            "const": "visual.sprite"
          },
          "version": {
            "const": 1
          },
          "replicated": {
            "const": false
          },
          "fields": {
            "type": "object",
            "required": [
              "assetId"
            ],
            "properties": {
              "assetId": {
                "type": "string",
                "minLength": 1
              },
              "width": {
                "type": "integer",
                "minimum": 1
              },
              "height": {
                "type": "integer",
                "minimum": 1
              },
              "layer": {
                "type": "integer"
              }
            },
            "additionalProperties": false
          }
        }
      }
    }
  ],
  "additionalProperties": false
}
