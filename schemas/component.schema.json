{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "component.schema.json",
  "title": "Component",
  "type": "object",
  "required": [
    "kind",
    "version",
    "replicated",
    "fields"
  ],
  "properties": {
    "kind": {
      "type": "string"
    },
    "version": {
      "type": "integer",
      "minimum": 1
    },
    "replicated": {
      "type": "boolean"
    },
    "fields": {
      "type": "object",
      "additionalProperties": true
    }
  },
  "additionalProperties": false
}